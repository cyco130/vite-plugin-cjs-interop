{
  "name": "vite-plugin-cjs-interop",
  "version": "4.0.3",
  "description": "Vite plugin to unwrap default imports from CJS dependencies during SSR",
  "keywords": [
    "cjs",
    "interop",
    "ssr",
    "vite-plugin"
  ],
  "license": "MIT",
  "repository": "github:cyco130/vite-plugin-cjs-interop",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown --clean",
    "dev": "tsdown --watch",
    "prepack": "pnpm build",
    "test": "pnpm run /^test:/",
    "test:unit": "vitest run",
    "test:typecheck": "tsc -p tsconfig.json",
    "test:lint": "eslint . --max-warnings 0",
    "test:package": "publint --strict"
  },
  "dependencies": {
    "estree-walker": "^3.0.3",
    "magic-string": "^0.30.21",
    "minimatch": "^10.2.5",
    "oxc-parser": "^0.134.0"
  },
  "devDependencies": {
    "@cyco130/eslint-config": "^9.0.2",
    "@types/node": "^22.19.20",
    "eslint": "^10.4.1",
    "publint": "^0.3.21",
    "tsdown": "0.22.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "vite": "~6.4 || ~7.3 || 8"
  },
  "engines": {
    "node": "22 || 24 || 25 || 26"
  }
}
