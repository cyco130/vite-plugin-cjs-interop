{
  "name": "vite-plugin-cjs-interop",
  "version": "3.3.0",
  "description": "Vite plugin to unwrap default imports from CJS dependencies during SSR",
  "keywords": [
    "cjs",
    "interop",
    "ssr",
    "vite-plugin"
  ],
  "license": "MIT",
  "repository": "github:cyco130/vite-plugin-cjs-interop",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "prepack": "rm -rf dist && pnpm build",
    "test": "pnpm run /^test:/",
    "test:unit": "vitest run",
    "test:typecheck": "tsc -p tsconfig.json --noEmit",
    "test:lint": "eslint . --max-warnings 0 --ignore-pattern dist",
    "test:package": "publint --strict"
  },
  "dependencies": {
    "estree-walker": "^3.0.3",
    "magic-string": "^0.30.21",
    "minimatch": "^10.2.5",
    "oxc-parser": "^0.125.0"
  },
  "devDependencies": {
    "@cyco130/eslint-config": "^7.0.1",
    "@types/node": "^20.19.39",
    "eslint": "^10.2.0",
    "publint": "^0.3.18",
    "tsdown": "0.21.8",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "vite": "~6.4 || ~7.3 || 8"
  },
  "engines": {
    "node": "20 || 22 || 24 || 25"
  }
}
