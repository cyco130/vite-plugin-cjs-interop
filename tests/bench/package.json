{
  "name": "vite-plugin-cjs-interop-bench",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:cjs": "vite build --config vite.config.cts",
    "start": "node dist/index.js",
