{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": ["config:recommended", "schedule:weekly", "group:allNonMajor"],
	"ignorePresets": ["ignorePaths"],
	"ignorePaths": ["**/node_modules/**", "**/dist/**"],
	"labels": ["dependencies"],
	"rangeStrategy": "bump",
	"minimumReleaseAge": "1 day",
	"packageRules": [
		{
			"matchPackageNames": ["@cyco130/eslint-config", "kill-em-all"],
			"minimumReleaseAge": "0"
		},
		{
			"matchManagers": ["github-actions"],
			"rangeStrategy": "replace"
		},
		{
			"matchDepTypes": ["peerDependencies"],
			"enabled": false
		},
		{
			"allowedVersions": "22",
			"matchPackageNames": ["/^@types/node$/"]
		},
		{
			"matchFileNames": ["tests/bench-vite5/package.json"],
			"matchPackageNames": ["vite"],
			"allowedVersions": "5",
			"rangeStrategy": "pin"
		},
		{
			"matchFileNames": ["tests/bench-vite6/package.json"],
			"matchPackageNames": ["vite"],
			"allowedVersions": "6",
			"rangeStrategy": "pin"
		},
		{
			"matchFileNames": ["tests/bench-vite7/package.json"],
			"matchPackageNames": ["vite"],
			"allowedVersions": "7",
			"rangeStrategy": "pin"
		},
		{
			"matchFileNames": ["tests/bench-vite8/package.json"],
			"matchPackageNames": ["vite"],
			"rangeStrategy": "pin"
		},
		{
			"matchFileNames": ["tests/bench-vite5/package.json"],
			"matchPackageNames": ["vitest"],
			"allowedVersions": "3",
			"rangeStrategy": "pin"
		}
	],
	"ignoreDeps": []
}
